# 服务配置
server:
  host: "0.0.0.0"
  port: 8888
  mode: "debug"  # debug, release, test
  read_timeout: 30
  write_timeout: 30

# 数据库配置
database:
  driver: "sqlite"  # sqlite, mysql, postgres
  
  # SQLite 配置（默认）
  db_name: "./data/app.db"  # 或 ":memory:" 表示内存数据库
  
  # MySQL 配置（如果使用 mysql）
  # host: "localhost"
  # port: 3306
  # user: "root"
  # password: ""
  # db_name: "my_service"
  
  # PostgreSQL 配置（如果使用 postgres）
  # host: "localhost"
  # port: 5432
  # user: "postgres"
  # password: ""
  # db_name: "my_service"
  # ssl_mode: "disable"

# Redis 配置（默认关闭）
# redis:
#   host: "localhost"
#   port: 6379
#   password: ""
#   db: 0

# 日志配置
log:
  level: "info"  # debug, info, warn, error
  filename: "logs/app.log"
  max_size: 100        # MB
  max_backups: 10      # 保留的旧日志文件数量
  max_age: 30          # 保留天数
  compress: true       # 是否压缩旧日志

# 应用配置
app:
  name: "my-service"
  version: "1.0.0"
